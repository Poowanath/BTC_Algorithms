# LINE Bot Configuration
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Get your credentials from:
# https://developers.line.biz/console/
# Go to your channel > Messaging API tab
# - Channel secret: Basic settings > Channel secret
# - Channel access token: Messaging API > Channel access token (long-lived)

# Base URL for webhook (ngrok or deployed URL)
BASE_URL=http://localhost:8000

# Hugging Face Prediction API (optional - if not set, will use local model)
# Example: https://your-username-btc-prediction-api.hf.space
HF_PREDICTION_API_URL=

# LINE User ID for receiving signal notifications
# Get this by sending any message to your bot and check the logs
LINE_USER_ID=
